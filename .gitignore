# Reproduce-input structure folders ship as packaged archives (extract before running);
# ignore the unpacked folders but DO commit the .tar.gz archives.
experiments/kinetics_thermo/data/init_pdbs/
experiments/protein_ligand_dynamics/data/init_structures/
experiments/atlas_benchmark/init_frames/
!experiments/kinetics_thermo/data/init_pdbs.tar.gz
!experiments/protein_ligand_dynamics/data/init_structures.tar.gz
!experiments/atlas_benchmark/init_frames.tar.gz

